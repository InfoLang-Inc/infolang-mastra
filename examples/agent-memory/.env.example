# Model provider used by the agent (Mastra's built-in model router).
OPENAI_API_KEY=sk-...

# InfoLang managed-cloud API key. Get one at https://infolang.ai.
INFOLANG_API_KEY=il_live_...

# Optional: point at a self-hosted InfoLang runtime instead of the managed
# cloud. If set, use INFOLANG_DEV_KEY (key:namespace) instead of
# INFOLANG_API_KEY in src/agent.ts.
# INFOLANG_BASE_URL=http://127.0.0.1:8766
